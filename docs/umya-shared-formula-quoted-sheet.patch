+#[cfg(test)]
+mod shared_formula_quoted_sheet_tests {
+    use super::*;
+
+    // Regression: a single-quoted sheet reference inside a formula with string
+    // literals must survive parse_to_tokens -> render unchanged. Before the fix
+    // the leading `'` was treated as a double-quoted string start, corrupting
+    // everything after it.
+    #[test]
+    fn quoted_sheet_ref_round_trips() {
+        let f = r#"IF(A2=1,'(1)'!$E$38&"-x","")"#;
+        let tokens = parse_to_tokens(format!("={}", f));
+        let rendered = render(&tokens);
+        assert_eq!(rendered, f, "render lost/corrupted the quoted sheet reference");
+    }
+
+    // Regression: shared-formula coordinate adjustment must preserve the quoted
+    // sheet name (it must NOT emit `(1)!$E$38`, which is invalid).
+    #[test]
+    fn shared_adjustment_preserves_quoted_sheet() {
+        let mut tokens = parse_to_tokens(r#"=IF(A2=1,'(1)'!$E$38&"-x","")"#);
+        // Simulate expanding the shared master (row 2) down to row 3.
+        let out = adjustment_insert_formula_coordinate(
+            &mut tokens, &0, &0, &2, &1, "", "Main", true,
+        );
+        assert!(
+            out.contains("'(1)'!$E$38"),
+            "quoted sheet ref was corrupted on shared expansion: {out}"
+        );
+        assert!(!out.contains("(1)!$E$38"), "sheet name lost its quotes: {out}");
+    }
+}

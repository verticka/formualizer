     if sheet_name == "" {
         return address.to_string();
     }
-    format!("{}!{}", sheet_name, address)
+    // `split_address` strips surrounding quotes for name comparison; re-add
+    // them here when the sheet name is not a bare identifier (contains spaces
+    // or special characters, or starts with a digit) so the rendered formula
+    // stays valid (e.g. `'(1)'!$E$38`, not `(1)!$E$38`). Internal single
+    // quotes are doubled, matching Excel quoting.
+    let needs_quoting = sheet_name.is_empty()
+        || sheet_name.starts_with(|c: char| c.is_ascii_digit())
+        || !sheet_name
+            .chars()
+            .all(|c| c.is_alphanumeric() || c == '_' || c == '.');
+    if needs_quoting {
+        format!("'{}'!{}", sheet_name.replace('\'', "''"), address)
+    } else {
+        format!("{}!{}", sheet_name, address)
+    }
 }
 
